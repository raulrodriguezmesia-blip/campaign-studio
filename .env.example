# Campaign Studio Environment Variables
# =====================================

# AI Provider: "openai" (default) or "groq"
AI_PROVIDER=openai

# OpenAI API Key (optional if using Groq)
OPENAI_API_KEY=

# Groq API Key (optional if using OpenAI)
# Get a free key at: https://console.groq.com/keys
GROQ_API_KEY=

# AI Model override (optional). Examples:
#   OpenAI:  gpt-4o-mini
#   Groq:    llama-3.1-8b-instruct, mixtral-8x7b-32768
AI_MODEL=

# AI Base URL override (optional). Examples:
#   OpenAI:  https://api.openai.com/v1
#   Groq:    https://api.groq.com/openai/v1
AI_BASE_URL=

# CORS allowed origins (comma-separated, no spaces)
# Frontend on Vercel + local dev. Adjust when you change the frontend URL.
CORS_ORIGINS=https://campaign-studio-new.vercel.app,http://localhost:8080,http://localhost:3000

# OpenTelemetry Configuration (Optional)
# Endpoint to export traces (default: otel-collector.istio-system.svc.cluster.local:4317)
OTEL_EXPORTER_OTLP_ENDPOINT=otel-collector.istio-system.svc.cluster.local:4317

# Sampling rate for traces (0.0 - 1.0)
OTEL_SAMPLING_RATE=1.0

# Environment (development, staging, production)
ENVIRONMENT=development

# Port for the server
PORT=8000
