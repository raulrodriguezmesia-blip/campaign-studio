# Campaign Studio Environment Variables
# =====================================

# OpenAI API Key (REQUIRED)
# Obtén tu API key en: https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-tu-api-key-aqui

# OpenTelemetry Configuration (Optional)
# Endpoint para exportar trazas (default: otel-collector.istio-system.svc.cluster.local:4317)
OTEL_EXPORTER_OTLP_ENDPOINT=otel-collector.istio-system.svc.cluster.local:4317

# Sampling rate for traces (0.0 - 1.0)
OTEL_SAMPLING_RATE=1.0

# Environment (development, staging, production)
ENVIRONMENT=development

# Port for the server
PORT=8000